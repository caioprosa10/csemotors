<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head') %>
<body>
    <div id="wrapper">
        <%- include('./partials/header') %>
        <%- include('./partials/navigation') %>

        <main>
            <h1>Welcome to CSE Motors!</h1>

            <section class="hero">
                <div class="hero-info">
                    <h2>DMC Delorean</h2>
                    <p>3 Cup holders<br>Superman doors<br>Fuzzy dice!</p>
                    <button class="own-today" type="button">Own Today</button>
                </div>
                <img src="/images/delorean.jpg" alt="DMC Delorean" class="delorean-img">
            </section>

            <div class="flex-content">
                <section class="reviews">
                    <h3>DMC Delorean Reviews</h3>
                    <ul>
                        <li>"So fast it's almost like traveling in time." (4/5)</li>
                        <li>"Coolest ride on the road." (4/5)</li>
                        <li>"I'm feeling McFly!" (5/5)</li>
                        <li>"The most futuristic ride of our day." (4.5/5)</li>
                        <li>"80's livin and I love it!" (5/5)</li>
                    </ul>
                </section>

                <section class="upgrades">
                    <h3>Delorean Upgrades</h3>
                    <div class="upgrade-grid">
                        <div class="u-item">
                            <div class="u-img-box">
                                <img src="/images/upgrades/flux-cap.png" alt="Flux Capacitor">
                            </div>
                            <a href="#">Flux Capacitor</a>
                        </div>
                        <div class="u-item">
                            <div class="u-img-box">
                                <img src="/images/upgrades/flame.png" alt="Flame Decals">
                            </div>
                            <a href="#">Flame Decals</a>
                        </div>
                        <div class="u-item">
                            <div class="u-img-box">
                                <img src="/images/upgrades/bumper_sticker.png" alt="Bumper Stickers">
                            </div>
                            <a href="#">Bumper Stickers</a>
                        </div>
                        <div class="u-item">
                            <div class="u-img-box">
                                <img src="/images/upgrades/hub-cap.png" alt="Hub Caps">
                            </div>
                            <a href="#">Hub Caps</a>
                        </div>
                    </div>
                </section>
            </div> 
        </main>

        <%- include('./partials/footer') %>
    </div>
</body>
</html>